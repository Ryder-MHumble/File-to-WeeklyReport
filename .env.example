OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTML_MODEL=minimax/minimax-m2.7
OPENROUTER_HTML_MAX_TOKENS=131072
# 结构化模型可替换为免费模型（示例：按你的 OpenRouter 可用模型填写）
OPENROUTER_STRUCTURED_MODEL=minimax/minimax-m2.7
# 可选：结构化润色模型；留空则关闭额外润色调用
OPENROUTER_POLISH_MODEL=
# 海报 brief 提炼模型；默认回退到结构化模型
OPENROUTER_POSTER_BRIEF_MODEL=minimax/minimax-m2.7
# 海报图片模型；默认支持 OpenRouter 图像生成
OPENROUTER_POSTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# 兼容旧命名（可不填）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_HTML_MODEL=
MINIMAX_STRUCTURED_MODEL=
MINIMAX_POLISH_MODEL=
MINIMAX_MODEL=

MAX_SOURCE_CHARS=18000

# 前端发布接口（可选；为空时默认同域 /api/reports/publish）
VITE_REPORT_API_BASE_URL=

# 如果前端开发服务与后端代理分开启动，可显式指向服务端地址
# 示例：VITE_REPORT_API_BASE_URL=http://127.0.0.1:5173

# 前端是否禁用服务端 OpenRouter 代理（1/true 表示禁用）
VITE_OPENROUTER_PROXY_DISABLED=

# 代理失败时是否允许前端自动直连（默认关闭，避免 usage 监控漏记）
VITE_OPENROUTER_ALLOW_DIRECT_FALLBACK=

# 生产服务监听配置
REPORT_SERVER_HOST=0.0.0.0
REPORT_SERVER_PORT=5173

# 分享链接基地址（可选；为空时自动按请求头推断）
PUBLIC_SHARE_BASE_URL=

# 报告发布接口请求体上限（字节）
REPORT_BODY_LIMIT_BYTES=6291456

# 报告清理策略：保留天数（0 表示不按天数清理）
REPORT_RETENTION_DAYS=30

# 报告清理策略：最多保留条数（0 表示不按数量清理）
REPORT_MAX_COUNT=500

# 启动时执行一次报告清理
REPORT_CLEANUP_ON_STARTUP=true

# 每次发布后后台触发报告清理
REPORT_CLEANUP_ON_PUBLISH=true

# OpenRouter 代理开关（默认 true）
OPENROUTER_PROXY_ENABLED=true

# OpenRouter 代理请求体上限（字节）
OPENROUTER_PROXY_BODY_LIMIT_BYTES=2097152

# 硅基流动（SiliconFlow）自动切换兜底配置
# 当日默认优先 OpenRouter，OpenRouter 失败后自动切换到硅基流动
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/moonshotai/Kimi-K2.6

# 用量记录保留天数（0 表示不按天数清理）
USAGE_RETENTION_DAYS=90

# 用量记录最大保留条数（0 表示不按数量清理）
USAGE_MAX_RECORDS=20000

# 每次记录写入后是否异步触发清理
USAGE_CLEANUP_ON_WRITE=true

# 可选：模型计费配置（美元 / 1M tokens）
# OPENROUTER_MODEL_PRICING_JSON={"minimax/minimax-m2.7":{"inputPer1M":0.3,"outputPer1M":1.2}}
